{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "..",
		"composite": true,
		"lib": ["esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node"]
	},
	"exclude": ["./**/*.test.ts", "./**/*.spec.ts"],
	"extends": "../tsconfig.base.json",
	"include": ["./**/*.ts", "./**/*.tsx", "./**/*.mts", "./**/*.cts"],
	"references": [{ "path": "../tsconfig.database.json" }]
}
