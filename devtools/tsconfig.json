{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "..",
		"composite": true,
		"lib": ["esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": false,
		"types": ["node"]
	},
	"exclude": ["./**/*.test.ts", "./**/*.spec.ts"],
	"extends": ["../tsconfig.base.json"],
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"./**/*.mts",
		"./**/*.cts",
		"../drizzle.config.ts"
	],
	"references": [
		{ "path": "../tsconfig.database.json" },
		{ "path": "../tsconfig.app.json" }
	]
}
