{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"exactOptionalPropertyTypes": false,
		"noPropertyAccessFromIndexSignature": false,
		"noUnusedLocals": false,
		"paths": {
			"@/*": ["./src/*"],
			"@cypress/*": ["./cypress/*"],
			"@database": ["./database/index.ts"],
			"@database/*": ["./database/*"],
			"@devtools": ["./devtools/index.ts"],
			"@devtools/*": ["./devtools/*"]
		}
	},
	"exclude": ["cypress", "cypress.config.ts", "node_modules", "out", "dist"],
	"extends": [
		"@tsconfig/bases/recommended",
		"@tsconfig/bases/strictest",
		"@tsconfig/bases/node-lts",
		"@tsconfig/bases/node-ts",
		"@tsconfig/bases/node24",
		"@tsconfig/bases/next"
	],
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.mts",
		"**/*.js",
		"**/*.jsx",
		"**/*.mjs"
	],
	"jsx": "react-jsx",
	"lib": [
		"esnext",
		"dom",
		"dom.iterable",
		"esnext.Array",
		"esnext.Collection",
		"esnext.Iterator",
		"esnext.Promise"
	],
	"target": "esnext"
}
