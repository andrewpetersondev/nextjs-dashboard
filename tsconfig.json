// biome-ignore-all assist/source/useSortedKeys: order matters in tsconfig files
{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": [
		"@tsconfig/bases/recommended",
		"@tsconfig/bases/strictest",
		"@tsconfig/bases/node-lts",
		"@tsconfig/bases/node-ts",
		"@tsconfig/bases/node24",
		"@tsconfig/bases/next"
	],
	"compilerOptions": {
		// Type Checking Options
		"exactOptionalPropertyTypes": false, // disabling from strictest base
		"noPropertyAccessFromIndexSignature": false, // disabling from strictest base
		"noUnusedLocals": false, // disabling from strictest base
		// Modules
		"baseUrl": ".", // need for path aliases
		"paths": {
			"@/*": ["./src/*"],
			"@cypress/*": ["./cypress/*"],
			"@database": ["./database/index.ts"],
			"@database/*": ["./database/*"],
			"@devtools": ["./devtools/index.ts"],
			"@devtools/*": ["./devtools/*"]
		},
		// Language and Environment
		"jsx": "react-jsx", // default setting from create next app
		"target": "esnext" // if module is nodenext, then target must be esnext
	},
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"database/**/*.ts",
		"devtools/**/*.ts",
		"drizzle.config.ts",
		"next.config.ts",
		"vitest.config.ts",
		"vitest.setup.ts"
	],
	"exclude": ["dist", "node_modules", "out"]
}
