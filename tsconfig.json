{
	"compilerOptions": {
		"allowJs": false,
		"allowUnreachableCode": false,
		"jsx": "react-jsx",
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noImplicitOverride": true,
		//    "noPropertyAccessFromIndexSignature": true,
		//    "noUnusedLocals": true,
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"exclude": ["node_modules", "**/*.test.ts"],
	"extends": "./tsconfig.base.json",
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"src/**/*"
	]
}
