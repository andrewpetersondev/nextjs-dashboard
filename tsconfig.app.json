{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"allowJs": false,
		"allowUnreachableCode": false,
		"composite": true,
		"jsx": "react-jsx",
		"plugins": [{ "name": "next" }],
		"sourceMap": false
	},
	"exclude": [
		"./src/**/__tests__/**/*",
		"./src/**/*.test.ts",
		"./src/**/*.spec.ts"
	],
	"extends": ["@tsconfig/next/tsconfig.json", "./tsconfig.base.json"],
	"include": [
		"./next-env.d.ts",
		"./.next/types/**/*.ts",
		"./.next/dev/types/**/*.ts",
		"./src/**/*.ts",
		"./src/**/*.tsx",
		"./src/**/*.mts",
		"./src/**/*.cts"
	],
	"references": [{ "path": "./tsconfig.database.json" }]
}
