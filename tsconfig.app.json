{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"allowJs": false,
		"allowUnreachableCode": false,
		"baseUrl": "./",
		"composite": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"jsx": "react-jsx",
		"noEmit": false,
		"paths": {
			"@/*": ["./src/*"],
			"@cypress/*": ["./cypress/*"],
			"@database": ["./database/index.ts"],
			"@database/*": ["./database/*"],
			"@devtools/*": ["./devtools/*"]
		},
		"plugins": [{ "name": "next" }],
		"sourceMap": false
	},
	"extends": ["@tsconfig/next/tsconfig.json", "./tsconfig.base.json"],
	"include": [
		"./next-env.d.ts",
		"./.next/types/**/*.ts",
		"./.next/dev/types/**/*.ts",
		"./src/**/*.ts",
		"./src/**/*.tsx",
		"./src/**/*.mts",
		"./src/**/*.cts",
		"next.config.ts"
	],
	"references": [{ "path": "./tsconfig.database.json" }]
}
