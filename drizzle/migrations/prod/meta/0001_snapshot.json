		"public.revenues": {
			"checkConstraints": {
				"revenues_invoice_count_non_negative": {
					"name": "revenues_invoice_count_non_negative",
					"value": "\"revenues\".\"invoice_count\" >= 0"
				},
				"revenues_paid_plus_pending_lte_total": {
					"name": "revenues_paid_plus_pending_lte_total",
					"value": "\"revenues\".\"total_paid_amount\" + \"revenues\".\"total_pending_amount\" <= \"revenues\".\"total_amount\""
				},
				"revenues_period_is_first_of_month": {
					"name": "revenues_period_is_first_of_month",
					"value": "extract(day from \"revenues\".\"period\") = 1"
