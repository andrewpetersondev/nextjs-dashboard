{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "..",
		"composite": true,
		"types": ["cypress", "node", "@testing-library/cypress", "cypress-axe"]
	},
	"extends": ["@tsconfig/cypress/tsconfig.json", "../tsconfig.json"],
	"include": [
		"../cypress.config.ts",
		"./**/*.ts",
		"./**/*.tsx",
		"../database/**/*.ts",
		"../devtools/**/*.ts"
	],
	"references": [{ "path": "../tsconfig.json" }]
}
