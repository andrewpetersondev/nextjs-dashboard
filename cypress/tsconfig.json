{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": "..",
		"composite": true,
		"lib": ["dom", "esnext"],
		"types": ["cypress", "node", "@testing-library/cypress", "cypress-axe"]
	},
	"extends": ["@tsconfig/cypress/tsconfig.json", "../tsconfig.test.json"],
	"include": [
		"../cypress.config.ts",
		"./**/*.ts",
		"./**/*.tsx",
		"./**/*.mts",
		"./**/*.cts"
	],
	"references": [
		{
			"path": "../tsconfig.app.json"
		},
		{
			"path": "../devtools"
		}
	]
}
