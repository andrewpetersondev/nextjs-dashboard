// biome-ignore-all assist/source/useSortedKeys: order matters in tsconfig files
{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": ["../tsconfig.json"],
	"compilerOptions": {
		"lib": ["es2020", "dom"],
		"module": "esnext",
		"moduleResolution": "bundler",
		//		"sourceMap": true,
		"target": "es2020",
		"types": ["cypress", "node", "@testing-library/cypress", "cypress-axe"]
	},
	"include": [
		"../cypress.config.ts",
		"./**/*.ts",
		"./**/*.tsx",
		"../database/**/*.ts"
	]
}
