// biome-ignore-all assist/source/useSortedKeys: order matters in tsconfig files
{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": ["../tsconfig.json"],
	"compilerOptions": {
		// Modules
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["cypress", "node", "@testing-library/cypress", "cypress-axe"],
		// Language and Environment
		"lib": ["esnext", "dom"],
		"target": "esnext"
	},
	"include": [
		"../cypress.config.ts",
		"./**/*.ts",
		"./**/*.tsx",
		"../database/**/*.ts"
	]
}
