{
	"$schema": "../node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"enabled": true
	},
	"extends": "//",
	"files": {
		"ignoreUnknown": true,
		"includes": ["../cypress.config.ts", "**", "!**/*.js", "!**/*.jsx"]
	},
	"formatter": {
		"enabled": true
	},
	"javascript": {
		"globals": ["cy", "Cypress"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": {
				"noExcessiveLinesPerFunction": "off"
			},
			"nursery": {
				"useExplicitType": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["support/commands.ts"],
			"linter": {
				"rules": {
					"style": "off"
				}
			}
		}
	],
	"root": false
}
