{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"extends": "//",
	"files": {
		"ignoreUnknown": true,
		"includes": ["../cypress.config.ts", "cypress/**", "!**/*.js", "!**/*.jsx"]
	},
	"javascript": {
		"globals": ["cy", "Cypress"]
	},
	"linter": {
		"rules": {
			"complexity": {
				"noExcessiveLinesPerFunction": "info"
			}
		}
	},
	"overrides": [
		{
			"includes": ["support/commands.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNamespace": "off"
					}
				}
			}
		}
	],
	"root": false
}
