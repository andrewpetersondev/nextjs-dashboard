{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"cypress": {
		"config": []
	},
	"drizzle": {
		"config": []
	},
	"entry": [
		"src/app/**/*.{ts,tsx}",
		"src/**/__tests__/**/*.{test,spec}.{ts,tsx}",
		"devtools/cli/**/*.cli.ts",
		"cypress.config.ts",
		"cypress/**/*.cy.{ts,tsx}",
		"cypress/support/**/*.{ts,tsx}",
		"drizzle.config.ts",
		"database/schema/relations.ts"
	],
	"ignoreDependencies": ["tailwindcss", "@testing-library/dom"],
	"project": [
		"src/**/*.{ts,tsx}",
		"devtools/**/*.{ts,tsx}",
		"cypress/**/*.{ts,tsx}",
		"test-support/**/*.{ts,tsx}",
		"database/**/*.{ts,tsx}",
		"*.{ts,mjs}"
	]
}
