{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/**/*.d.ts",

    "devtools/**/*.{ts,tsx}"
  ],

  "ignore": ["cypress/**", "cypress.config.ts", "drizzle.config.ts"],
  "ignoreExportsUsedInFile": false,
  "project": ["./tsconfig.json", "**/*.{ts,tsx}"]
}
