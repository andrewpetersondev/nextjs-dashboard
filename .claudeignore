# === Identical content shared with .claudeignore (.gitignore syntax) ===

# Dependencies & build output
node_modules/
.next/
out/
build/
dist/
.turbo/
.cache/
coverage/
*.tsbuildinfo
.npmrc

# Cypress artifacts
cypress/videos/
cypress/screenshots/
cypress/downloads/

# Logs & temp
logs/
*.log
tmp/
temp/

# Env / secrets
.env*
!.env.example

# Deploy
.vercel/

# Database dumps & backups
db_dumps/
dumps/
backups/
*.dump
*.psql

# Keys & certificates
*.pem
*.key
*.crt
*.pfx
*.p12
*.p8
*.der
