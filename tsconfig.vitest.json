{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"composite": true,
		"types": ["vitest/globals", "node"]
	},
	"extends": "./tsconfig.test.json",
	"include": [
		"./vitest.config.ts",
		"./vitest.setup.ts",
		"./src/**/__tests__/**/*",
		"./src/**/__tests__/**/*.ts",
		"./src/**/*.test.ts",
		"./src/**/*.spec.ts"
	],
	"references": [
		{
			"path": "./tsconfig.app.json"
		},
		{
			"path": "./tsconfig.database.json"
		}
	]
}
