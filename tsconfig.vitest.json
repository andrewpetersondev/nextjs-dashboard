{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"composite": true,
		"types": ["vitest/globals", "node"]
	},
	"extends": ["./tsconfig.app.json"],
	"include": [
		"./vitest.config.ts",
		"./vitest.setup.ts",
		"./src/**/*.test.ts",
		"./src/**/*.spec.ts"
	],
	"references": [
		{
			"path": "./tsconfig.app.json"
		},
		{
			"path": "./tsconfig.database.json"
		}
	]
}
