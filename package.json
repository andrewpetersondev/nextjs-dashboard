{
	"$schema": "https://json.schemastore.org/package",
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@next/env": "^16.2.9",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"jose": "^6.2.3",
		"next": "^16.2.9",
		"pg": "^8.21.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.6.0",
		"use-debounce": "^10.1.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/cypress": "^10.1.3",
		"@testing-library/dom": "^10.4.1",
		"@tsconfig/bases": "^1.0.25",
		"@types/node": "^25.9.2",
		"@types/pg": "^8.20.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "4.1.8",
		"@vitest/ui": "4.1.8",
		"axe-core": "^4.12.0",
		"cypress": "^15.17.0",
		"cypress-axe": "^1.7.0",
		"dotenv": "^17.4.2",
		"dotenv-cli": "^11.0.0",
		"dprint": "^0.54.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-seed": "^0.3.1",
		"knip": "^6.16.1",
		"markdownlint-cli2": "^0.22.1",
		"postcss": "^8.5.15",
		"rimraf": "^6.1.3",
		"start-server-and-test": "^3.0.9",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.8"
	},
	"name": "nextjs-dashboard",
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
	"private": true,
	"scripts": {
		"biome:format": "biome format --write",
		"biome:format:check": "biome format .",
		"biome:lint": "biome check",
		"biome:lint:fix": "biome check --write",
		"biome:summary": "biome check --reporter=summary",
		"check": "pnpm biome:lint && pnpm md:check && pnpm typecheck && pnpm next:typegen && pnpm test:all && pnpm cy:e2e",
		"check:fast": "pnpm biome:lint && pnpm md:check && pnpm typecheck && pnpm next:typegen",
		"check:repo": "pnpm check && pnpm knip",
		"clean": "rimraf .next && pnpm clean:generated",
		"clean:all": "pnpm clean && pnpm clean:generated && pnpm clean:deps",
		"clean:deps": "rimraf node_modules",
		"clean:generated": "rimraf --glob \"**/*.{js,map,tsbuildinfo}\"",
		"cy:clean": "rimraf cypress.config.js cypress.config.d.ts",
		"cy:e2e": "pnpm cy:clean && pnpm env:test:pnpm tsx --tsconfig tsconfig.json devtools/cli/cypress-with-server.cli.ts run",
		"cy:e2e:ci": "pnpm cy:e2e",
		"cy:e2e:open": "pnpm cy:clean && pnpm env:test:pnpm cypress open --e2e",
		"cy:e2e:run": "pnpm cy:clean && pnpm env:test:pnpm cypress run --e2e",
		"cy:open": "pnpm cy:e2e:open",
		"cy:open:with-server": "pnpm cy:clean && pnpm env:test:pnpm tsx --tsconfig tsconfig.json devtools/cli/cypress-with-server.cli.ts open",
		"cy:run": "pnpm cy:e2e:run",
		"cy:server": "pnpm next:dev:test",
		"db:generate:dev": "pnpm env:dev drizzle-kit generate",
		"db:generate:prod": "pnpm env:prod drizzle-kit generate",
		"db:generate:test": "pnpm env:test drizzle-kit generate",
		"db:migrate:dev": "pnpm env:dev drizzle-kit migrate",
		"db:migrate:prod": "pnpm env:prod drizzle-kit migrate",
		"db:migrate:test": "pnpm env:test drizzle-kit migrate",
		"db:push:dev": "pnpm db:generate:dev && pnpm db:migrate:dev",
		"db:push:prod": "pnpm db:generate:prod && pnpm db:migrate:prod",
		"db:push:test": "pnpm db:generate:test && pnpm db:migrate:test",
		"db:reset": "pnpm tsx --tsconfig tsconfig.json devtools/cli/reset.cli.ts",
		"db:reset:dev": "pnpm env:dev:pnpm db:reset",
		"db:reset:prod": "pnpm env:prod:pnpm db:reset",
		"db:reset:test": "pnpm env:test:pnpm db:reset",
		"db:seed": "pnpm tsx --tsconfig tsconfig.json devtools/cli/seed.cli.ts",
		"db:seed:dev": "pnpm env:dev:pnpm db:seed",
		"db:seed:prod": "pnpm env:prod:pnpm db:seed",
		"db:seed:test": "pnpm env:test:pnpm db:seed",
		"db:studio:dev": "pnpm env:dev drizzle-kit studio",
		"db:studio:test": "pnpm env:test drizzle-kit studio",
		"env:dev": "dotenv -e .env.development.local --",
		"env:dev:pnpm": "dotenv -e .env.development.local -- pnpm",
		"env:prod": "dotenv -e .env.production.local --",
		"env:prod:pnpm": "dotenv -e .env.production.local -- pnpm",
		"env:test": "dotenv -e .env.test.local --",
		"env:test:pnpm": "dotenv -e .env.test.local -- pnpm",
		"knip": "knip",
		"md:check": "pnpm md:lint && pnpm md:format:check",
		"md:fix": "pnpm md:lint:fix && pnpm md:format",
		"md:format": "dprint fmt",
		"md:format:check": "dprint check",
		"md:lint": "markdownlint-cli2",
		"md:lint:fix": "markdownlint-cli2 --fix",
		"next:build": "next build",
		"next:build:standalone": "pnpm clean && pnpm env:prod next build",
		"next:build:standalone:test": "pnpm clean && pnpm env:test next build",
		"next:build:test": "pnpm env:test next build",
		"next:dev": "next dev",
		"next:dev:test": "pnpm env:test next dev",
		"next:start": "next start",
		"next:start:standalone": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && pnpm env:prod:pnpm node .next/standalone/server.js",
		"next:start:standalone:test": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && pnpm env:test:pnpm node .next/standalone/server.js",
		"next:typegen": "next typegen && pnpm typecheck:app",
		"serve:standalone": "pnpm clean && pnpm next:build:standalone && pnpm next:start:standalone",
		"serve:test": "pnpm clean && pnpm next:build:standalone:test && pnpm next:start:standalone:test",
		"test": "pnpm test:unit",
		"test:all": "pnpm test:unit && pnpm test:integration",
		"test:coverage": "vitest run --project unit --coverage",
		"test:integration": "pnpm env:test vitest run --project integration",
		"test:ui": "vitest --ui",
		"test:unit": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"typecheck": "tsc -b tsconfig.json",
		"typecheck:app": "tsc --project tsconfig.json --noEmit",
		"typecheck:cypress": "tsc --project cypress/tsconfig.json --noEmit"
	},
	"type": "module",
	"version": "0.1.0"
}
