{
	"$schema": "https://json.schemastore.org/package",
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@next/env": "16.1.6",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"jose": "^6.2.1",
		"next": "16.1.6",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.5.0",
		"use-debounce": "^10.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/cypress": "^10.1.0",
		"@tsconfig/bases": "^1.0.23",
		"@tsconfig/cypress": "^1.0.5",
		"@tsconfig/next": "^2.0.6",
		"@tsconfig/node-lts": "^24.0.0",
		"@tsconfig/node-ts": "^23.6.4",
		"@tsconfig/recommended": "^1.0.13",
		"@types/node": "^25.3.5",
		"@types/pg": "^8.18.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"axe-core": "^4.11.1",
		"cypress": "^15.11.0",
		"cypress-axe": "^1.7.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-seed": "^0.3.1",
		"knip": "^5.86.0",
		"postcss": "^8.5.8",
		"rimraf": "^6.1.3",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	},
	"name": "nextjs-dashboard",
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
	"pnpm": {
		"overrides": {
			"esbuild": "^0.25.0"
		}
	},
	"private": true,
	"scripts": {
		"biome:summary": "biome check --reporter=summary",
		"build": "next build",
		"build:standalone": "pnpm clean && pnpm build",
		"build:test": "pnpm env:test next build",
		"check": "pnpm lint && pnpm typecheck && pnpm next:typegen && pnpm test",
		"check:fast": "pnpm lint && pnpm typecheck",
		"check:full": "pnpm lint && pnpm typecheck && pnpm test && pnpm e2e:run",
		"check:repo": "pnpm check:full && pnpm knip",
		"clean": "rimraf .next",
		"clean:all": "pnpm clean && pnpm clean:generated && pnpm clean:deps",
		"clean:deps": "rimraf node_modules",
		"clean:generated": "rimraf --glob \"**/*.{js,js.map,mjs.map,cjs,cjs.map,tsbuildinfo}\"",
		"db:generate:dev": "pnpm env:dev drizzle-kit generate",
		"db:generate:prod": "pnpm env:prod drizzle-kit generate",
		"db:generate:test": "pnpm env:test drizzle-kit generate",
		"db:migrate:dev": "pnpm env:dev drizzle-kit migrate",
		"db:migrate:prod": "pnpm env:prod drizzle-kit migrate",
		"db:migrate:test": "pnpm env:test drizzle-kit migrate",
		"db:push:dev": "pnpm db:generate:dev && pnpm db:migrate:dev",
		"db:push:prod": "pnpm db:generate:prod && pnpm db:migrate:prod",
		"db:push:test": "pnpm db:generate:test && pnpm db:migrate:test",
		"db:reset": "pnpm tsx --tsconfig devtools/tsconfig.json devtools/cli/reset.cli.ts",
		"db:reset:dev": "pnpm env:dev db:reset",
		"db:reset:prod": "pnpm env:prod db:reset",
		"db:reset:test": "pnpm env:test db:reset",
		"db:seed": "pnpm tsx --tsconfig devtools/tsconfig.json devtools/cli/seed.cli.ts",
		"db:seed:dev": "pnpm env:dev db:seed",
		"db:seed:prod": "pnpm env:prod db:seed",
		"db:seed:test": "pnpm env:test db:seed",
		"db:studio:dev": "pnpm env:dev drizzle-kit studio",
		"db:studio:test": "pnpm env:test drizzle-kit studio",
		"dev": "next dev",
		"e2e:open": "pnpm env:test cypress open --e2e",
		"e2e:run": "pnpm env:test cypress run --e2e",
		"env:dev": "dotenv -e .env.development.local --",
		"env:dev:pnpm": "dotenv -e .env.development.local -- pnpm",
		"env:prod": "dotenv -e .env.production.local --",
		"env:prod:pnpm": "dotenv -e .env.production.local -- pnpm",
		"env:test": "dotenv -e .env.test.local --",
		"env:test:pnpm": "dotenv -e .env.test.local -- pnpm",
		"format": "biome format --write",
		"format:check": "biome format",
		"knip": "knip",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"next:typegen": "next typegen && pnpm typecheck:app",
		"serve:standalone": "pnpm clean && pnpm build && pnpm start:standalone",
		"serve:test": "pnpm env:test:pnpm start:standalone",
		"start": "next start",
		"start:standalone": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && node .next/standalone/server.js",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"typecheck": "tsc -b tsconfig.json",
		"typecheck:app": "tsc --project tsconfig.app.json --noEmit",
		"typecheck:cypress": "tsc --project cypress/tsconfig.json --noEmit",
		"typecheck:database": "tsc --project tsconfig.database.json --noEmit",
		"typecheck:devtools": "tsc --project devtools/tsconfig.json --noEmit",
		"typecheck:tooling": "tsc --project tsconfig.root-tools.json --noEmit",
		"typecheck:vitest": "tsc --project tsconfig.vitest.json --noEmit"
	},
	"type": "module",
	"version": "0.1.0"
}
