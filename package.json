{
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@next/env": "16.1.6",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"jose": "^6.2.0",
		"next": "16.1.6",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.5.0",
		"use-debounce": "^10.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/cypress": "^10.1.0",
		"@types/node": "^25.3.5",
		"@types/pg": "^8.18.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"axe-core": "^4.11.1",
		"cypress": "^15.11.0",
		"cypress-axe": "^1.7.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-seed": "^0.3.1",
		"knip": "^5.85.0",
		"postcss": "^8.5.8",
		"rimraf": "^6.1.3",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	},
	"name": "nextjs-dashboard",
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"pnpm": {
		"overrides": {
			"esbuild": "^0.25.0"
		}
	},
	"private": true,
	"scripts": {
		"biome:summary": "biome check --reporter=summary",
		"build": "next build --turbopack",
		"build:test": "pnpm env:test next build --turbopack",
		"check": "pnpm lint && pnpm typecheck && pnpm test",
		"clean": "rimraf .next",
		"clean:all": "biome clean && rimraf .next node_modules",
		"cyp:e2e:headless": "pnpm e2e:run",
		"cyp:open": "pnpm env:test cypress open --e2e",
		"db:generate:migrate:dev": "pnpm env:dev drizzle-kit generate && pnpm env:dev drizzle-kit migrate",
		"db:generate:migrate:prod": "pnpm env:prod drizzle-kit generate && pnpm env:prod drizzle-kit migrate",
		"db:generate:migrate:test": "pnpm env:test drizzle-kit generate && pnpm env:test drizzle-kit migrate",
		"db:reset:dev": "pnpm env:dev tsx --tsconfig devtools/tsconfig.json devtools/cli/reset-cli.ts",
		"db:reset:prod": "pnpm env:prod tsx --tsconfig devtools/tsconfig.json devtools/cli/reset-cli.ts",
		"db:reset:test": "pnpm env:test tsx --tsconfig devtools/tsconfig.json devtools/cli/reset-cli.ts",
		"db:seed:dev": "pnpm env:dev tsx --tsconfig devtools/tsconfig.json devtools/cli/seed-cli.ts",
		"db:seed:prod": "pnpm env:prod tsx --tsconfig devtools/tsconfig.json devtools/cli/seed-cli.ts",
		"db:seed:test": "pnpm env:test tsx --tsconfig devtools/tsconfig.json devtools/cli/seed-cli.ts",
		"db:studio:dev": "pnpm env:dev drizzle-kit studio",
		"db:studio:test": "pnpm env:test drizzle-kit studio",
		"dev": "next dev --turbopack",
		"e2e:open": "pnpm env:test cypress open --e2e",
		"e2e:run": "pnpm env:test cypress run --e2e",
		"env:dev": "dotenv -e .env.development.local --",
		"env:prod": "dotenv -e .env.production.local --",
		"env:test": "dotenv -e .env.test.local --",
		"env:test:pnpm": "dotenv -e .env.test.local -- pnpm",
		"format": "biome format --write",
		"knip": "knip",
		"lint": "biome check",
		"serve:test": "pnpm env:test:pnpm start:standalone",
		"standalone": "pnpm clean && pnpm build && pnpm start:standalone",
		"start": "next start",
		"start:standalone": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && node .next/standalone/server.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"type:gen": "next typegen && pnpm typecheck:app",
		"typecheck": "pnpm typecheck:app && pnpm typecheck:tooling && pnpm typecheck:database && pnpm typecheck:devtools && pnpm typecheck:test && pnpm typecheck:cypress",
		"typecheck:app": "tsc -p tsconfig.json --noEmit",
		"typecheck:cypress": "tsc -p cypress/tsconfig.json --noEmit",
		"typecheck:database": "tsc -p tsconfig.database.json --noEmit",
		"typecheck:devtools": "tsc -p devtools/tsconfig.json --noEmit",
		"typecheck:tooling": "tsc -p tsconfig.tooling.json --noEmit",
		"typecheck:vitest": "tsc -p tsconfig.vitest.json --noEmit"
	},
	"type": "module",
	"version": "0.1.0"
}
