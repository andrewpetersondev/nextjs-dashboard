{
	"$schema": "https://json.schemastore.org/package",
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@next/env": "16.1.6",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"jose": "^6.2.1",
		"next": "16.1.6",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.5.0",
		"use-debounce": "^10.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/cypress": "^10.1.0",
		"@testing-library/dom": "^10.4.1",
		"@tsconfig/bases": "^1.0.23",
		"@tsconfig/cypress": "^1.0.5",
		"@tsconfig/next": "^2.0.6",
		"@tsconfig/node-lts": "^24.0.0",
		"@tsconfig/node-ts": "^23.6.4",
		"@tsconfig/recommended": "^1.0.13",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"axe-core": "^4.11.1",
		"cypress": "^15.12.0",
		"cypress-axe": "^1.7.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-seed": "^0.3.1",
		"knip": "^5.86.0",
		"postcss": "^8.5.8",
		"rimraf": "^6.1.3",
		"start-server-and-test": "^2.1.5",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": "25"
	},
	"name": "nextjs-dashboard",
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"pnpm": {
		"overrides": {
			"esbuild": "^0.25.0"
		}
	},
	"private": true,
	"scripts": {
		"biome:format": "biome format --write",
		"biome:format:check": "biome format",
		"biome:lint": "biome check",
		"biome:lint:fix": "biome check --write",
		"biome:summary": "biome check --reporter=summary",
		"check": "pnpm biome:lint && pnpm typecheck && pnpm next:typegen && pnpm test",
		"check:fast": "pnpm biome:lint && pnpm typecheck",
		"check:full": "pnpm biome:lint && pnpm typecheck && pnpm test && pnpm cy:e2e",
		"check:repo": "pnpm check:full && pnpm knip",
		"clean": "rimraf .next",
		"clean:all": "pnpm clean && pnpm clean:generated && pnpm clean:deps",
		"clean:deps": "rimraf node_modules",
		"clean:generated": "rimraf --glob \"**/*.{js,map,tsbuildinfo}\"",
		"cy:e2e": "pnpm env:test:pnpm start-server-and-test next:dev:test http://localhost:3001 cy:e2e:run",
		"cy:e2e:ci": "pnpm cy:e2e",
		"cy:e2e:open": "pnpm env:test:pnpm cypress open --e2e",
		"cy:e2e:run": "pnpm env:test:pnpm cypress run --e2e",
		"cy:open": "pnpm env:test:pnpm cypress open",
		"cy:run": "pnpm env:test:pnpm cypress run",
		"db:generate:dev": "pnpm env:dev drizzle-kit generate",
		"db:generate:prod": "pnpm env:prod drizzle-kit generate",
		"db:generate:test": "pnpm env:test drizzle-kit generate",
		"db:migrate:dev": "pnpm env:dev drizzle-kit migrate",
		"db:migrate:prod": "pnpm env:prod drizzle-kit migrate",
		"db:migrate:test": "pnpm env:test drizzle-kit migrate",
		"db:push:dev": "pnpm db:generate:dev && pnpm db:migrate:dev",
		"db:push:prod": "pnpm db:generate:prod && pnpm db:migrate:prod",
		"db:push:test": "pnpm db:generate:test && pnpm db:migrate:test",
		"db:reset": "pnpm tsx --tsconfig tsconfig.json devtools/cli/reset.cli.ts",
		"db:reset:dev": "pnpm env:dev db:reset",
		"db:reset:prod": "pnpm env:prod db:reset",
		"db:reset:test": "pnpm env:test db:reset",
		"db:seed": "pnpm tsx --tsconfig tsconfig.json devtools/cli/seed.cli.ts",
		"db:seed:dev": "pnpm env:dev db:seed",
		"db:seed:prod": "pnpm env:prod db:seed",
		"db:seed:test": "pnpm env:test db:seed",
		"db:studio:dev": "pnpm env:dev drizzle-kit studio",
		"db:studio:test": "pnpm env:test drizzle-kit studio",
		"env:dev": "dotenv -e .env.development.local --",
		"env:dev:pnpm": "dotenv -e .env.development.local -- pnpm",
		"env:prod": "dotenv -e .env.production.local --",
		"env:prod:pnpm": "dotenv -e .env.production.local -- pnpm",
		"env:test": "dotenv -e .env.test.local --",
		"env:test:pnpm": "dotenv -e .env.test.local -- pnpm",
		"knip": "knip",
		"next:build": "next build",
		"next:build:standalone": "pnpm clean && pnpm next:build",
		"next:build:test": "pnpm env:test next build",
		"next:dev": "next dev",
		"next:dev:test": "pnpm env:test next dev -p 3001",
		"next:start": "next start",
		"next:start:standalone": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && node .next/standalone/server.js",
		"next:typegen": "next typegen && pnpm typecheck:app",
		"serve:standalone": "pnpm clean && pnpm next:build && pnpm next:start:standalone",
		"serve:test": "pnpm env:test:pnpm next:start:standalone",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"typecheck": "tsc -b tsconfig.json",
		"typecheck:app": "tsc --project tsconfig.json --noEmit",
		"typecheck:cypress": "tsc --project cypress/tsconfig.json --noEmit"
	},
	"type": "module",
	"version": "0.1.0"
}
