# === Shared ignore list — keep identical between .aiignore and .claudeignore (.gitignore syntax) ===

# Dependencies & build output
out/
build/
dist/
.turbo/
.cache/
coverage/
*.tsbuildinfo
.npmrc

# Cypress artifacts
cypress/videos/
cypress/screenshots/
cypress/downloads/

# Logs & temp
logs/
*.log
tmp/
temp/

# Env / secrets
.env*
!.env.example
.envrc
.direnv/
.vault/
.vault-token
vault/
secrets/
password.txt

# Deploy
.vercel/

# Database data, dumps & backups
pgdata/
postgres-data/
docker/postgres-data/
db_dumps/
dumps/
backups/
*.dump
*.psql

# Keys & certificates
postgres-certs/
*.pem
*.key
*.crt
*.pfx
*.p12
*.p8
*.der
